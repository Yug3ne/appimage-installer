#!/usr/bin/env bash
# appimage-install — Extract AppImages for faster, lighter execution
# No FUSE, no tmpfs RAM usage, proper desktop integration with icons
#
# Usage:
#   appimage-install <file.AppImage>              # Install with auto-detected name
#   appimage-install <file.AppImage> --name myapp # Install with custom name
#   appimage-install --update <name>              # Update an installed app
#   appimage-install --list                       # List installed apps
#   appimage-install --remove <name>              # Remove an installed app
#   appimage-install --help                       # Show help

set -uo pipefail

INSTALL_DIR="${HOME}/.local/opt"
DESKTOP_DIR="${HOME}/.local/share/applications"
BIN_DIR="${HOME}/.local/bin"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info()  { echo -e "${BLUE}::${NC} $*"; }
ok()    { echo -e "${GREEN}✓${NC} $*"; }
warn()  { echo -e "${YELLOW}!${NC} $*"; }
error() { echo -e "${RED}✗${NC} $*" >&2; }

usage() {
    cat <<'EOF'
appimage-install — Extract & install AppImages without FUSE overhead

USAGE:
    appimage-install <file.AppImage>              Install with auto-detected name
    appimage-install <file.AppImage> --name myapp Install with custom name
    appimage-install --update <name>              Update an installed app from GitHub
    appimage-install --update-all                 Update all installed apps
    appimage-install --list                       List installed apps
    appimage-install --remove <name>              Remove an installed app

OPTIONS:
    --name <name>    Override the app name (used for folder and command name)
    --no-sandbox     Add --no-sandbox flag to Exec (needed for Electron apps)
    --help           Show this help

EXAMPLES:
    appimage-install ~/Downloads/MyApp.AppImage
    appimage-install MyApp.AppImage --name myapp
    appimage-install --update t3code
    appimage-install --update-all
    appimage-install --remove myapp
    appimage-install --list

WHAT IT DOES:
    1. Extracts the AppImage (no more FUSE/tmpfs RAM usage)
    2. Moves it to ~/.local/opt/<name>/
    3. Finds the icon and creates a .desktop entry
    4. Creates a symlink in ~/.local/bin/ for terminal launch
    5. Removes the original .AppImage file

AUTO-UPDATE:
    Apps installed from GitHub-released AppImages can be updated with --update.
    The script reads app-update.yml from the installed app to find the GitHub
    repo, checks for a newer release, downloads the new AppImage, and
    re-extracts it — preserving your desktop entry and command.

EOF
    exit 0
}

find_icon() {
    local app_dir="$1"
    local icon=""

    # Look for the largest PNG icon in hicolor
    icon=$(find "${app_dir}/usr/share/icons" -name "*.png" 2>/dev/null \
        | sort -t/ -k8 -rn \
        | head -1)

    # Fallback: any .png in the root of the extracted dir
    if [[ -z "$icon" ]]; then
        icon=$(find "${app_dir}" -maxdepth 1 -name "*.png" 2>/dev/null | head -1)
    fi

    # Fallback: any .svg
    if [[ -z "$icon" ]]; then
        icon=$(find "${app_dir}" -name "*.svg" 2>/dev/null | head -1)
    fi

    echo "$icon"
}

find_desktop_file() {
    local app_dir="$1"
    find "${app_dir}" -maxdepth 1 -name "*.desktop" 2>/dev/null | head -1
}

detect_name() {
    local app_dir="$1"
    local desktop_file
    desktop_file=$(find_desktop_file "$app_dir")

    if [[ -n "$desktop_file" ]]; then
        # Try to get StartupWMClass or Name from the embedded .desktop
        local wm_class
        wm_class=$(grep -i "^StartupWMClass=" "$desktop_file" 2>/dev/null | cut -d= -f2 | tr '[:upper:]' '[:lower:]' | tr ' ' '-')
        if [[ -n "$wm_class" ]]; then
            echo "$wm_class"
            return
        fi
    fi

    # Fallback: derive from AppImage filename
    local basename
    basename=$(basename "$APPIMAGE_PATH" .AppImage)
    basename=$(echo "$basename" | sed -E 's/-[0-9]+\..*//' | sed 's/_x86_64//' | sed 's/_aarch64//' | tr '[:upper:]' '[:lower:]' | tr ' _' '-')
    echo "$basename"
}

detect_display_name() {
    local app_dir="$1"
    local desktop_file
    desktop_file=$(find_desktop_file "$app_dir")

    if [[ -n "$desktop_file" ]]; then
        local name
        name=$(grep -i "^Name=" "$desktop_file" 2>/dev/null | head -1 | cut -d= -f2)
        if [[ -n "$name" ]]; then
            echo "$name"
            return
        fi
    fi

    basename "$APPIMAGE_PATH" .AppImage | sed -E 's/-[0-9]+\..*//'
}

detect_categories() {
    local app_dir="$1"
    local desktop_file
    desktop_file=$(find_desktop_file "$app_dir")

    if [[ -n "$desktop_file" ]]; then
        local cats
        cats=$(grep -i "^Categories=" "$desktop_file" 2>/dev/null | cut -d= -f2)
        if [[ -n "$cats" ]]; then
            echo "$cats"
            return
        fi
    fi

    echo "Utility;"
}

detect_wm_class() {
    local app_dir="$1"
    local desktop_file
    desktop_file=$(find_desktop_file "$app_dir")

    if [[ -n "$desktop_file" ]]; then
        grep -i "^StartupWMClass=" "$desktop_file" 2>/dev/null | cut -d= -f2
    fi
}

detect_mimetype() {
    local app_dir="$1"
    local desktop_file
    desktop_file=$(find_desktop_file "$app_dir")

    if [[ -n "$desktop_file" ]]; then
        grep -i "^MimeType=" "$desktop_file" 2>/dev/null | cut -d= -f2
    fi
}

get_update_info() {
    local install_path="$1"
    local yml=""

    # Look for app-update.yml (electron-updater config)
    yml=$(find "$install_path" -name "app-update.yml" -path "*/resources/*" 2>/dev/null | head -1)

    if [[ -z "$yml" ]]; then
        return 1
    fi

    echo "$yml"
}

get_current_version() {
    local install_path="$1"

    # Try embedded .desktop file inside the app (most reliable)
    local embedded_desktop
    embedded_desktop=$(find "$install_path" -maxdepth 1 -name "*.desktop" 2>/dev/null | head -1)
    if [[ -n "$embedded_desktop" ]]; then
        local ver
        ver=$(grep "^X-AppImage-Version=" "$embedded_desktop" 2>/dev/null | cut -d= -f2)
        if [[ -n "$ver" ]]; then
            echo "$ver"
            return
        fi
    fi

    # Try our desktop entry
    local desktop_file="${DESKTOP_DIR}/$(basename "$install_path").desktop"
    if [[ -f "$desktop_file" ]]; then
        local ver
        ver=$(grep "^X-AppImage-Version=" "$desktop_file" 2>/dev/null | cut -d= -f2)
        if [[ -n "$ver" ]]; then
            echo "$ver"
            return
        fi
    fi

    echo "unknown"
}

do_update() {
    local app_name="$1"

    if [[ -z "$app_name" ]]; then
        error "Usage: appimage-install --update <name>"
        echo "Run 'appimage-install --list' to see installed apps"
        exit 1
    fi

    local install_path="${INSTALL_DIR}/${app_name}"

    if [[ ! -d "$install_path" ]]; then
        error "App '${app_name}' not found at ${install_path}"
        echo "Run 'appimage-install --list' to see installed apps"
        exit 1
    fi

    # Get update info
    local yml
    yml=$(get_update_info "$install_path")
    if [[ -z "$yml" ]]; then
        error "No app-update.yml found — cannot determine update source"
        echo "You can manually download the new AppImage and run:"
        echo "  appimage-install new-version.AppImage --name ${app_name}"
        exit 1
    fi

    # Parse GitHub owner/repo
    local owner repo provider
    owner=$(grep "^owner:" "$yml" | awk '{print $2}' | tr -d '[:space:]')
    repo=$(grep "^repo:" "$yml" | awk '{print $2}' | tr -d '[:space:]')
    provider=$(grep "^provider:" "$yml" | awk '{print $2}' | tr -d '[:space:]')

    if [[ "$provider" != "github" ]]; then
        error "Only GitHub provider is supported (found: ${provider})"
        exit 1
    fi

    if [[ -z "$owner" || -z "$repo" ]]; then
        error "Could not parse owner/repo from ${yml}"
        exit 1
    fi

    info "Checking ${owner}/${repo} for updates..."

    # Get current version
    local current_version
    current_version=$(get_current_version "$install_path")
    info "Current version: ${current_version}"

    # Get latest release from GitHub
    local release_json
    release_json=$(curl -sL "https://api.github.com/repos/${owner}/${repo}/releases/latest")

    local latest_version
    latest_version=$(echo "$release_json" | grep -o '"tag_name"[[:space:]]*:[[:space:]]*"[^"]*"' | cut -d'"' -f4 | sed 's/^v//')

    if [[ -z "$latest_version" ]]; then
        error "Could not fetch latest release from GitHub"
        echo "$release_json" | head -5
        exit 1
    fi

    info "Latest version:  ${latest_version}"

    if [[ "$current_version" == "$latest_version" ]]; then
        ok "Already up to date!"
        return 0
    fi

    # Find the AppImage download URL
    local download_url
    download_url=$(echo "$release_json" | grep -o '"browser_download_url"[[:space:]]*:[[:space:]]*"[^"]*\.AppImage"' | cut -d'"' -f4 | grep -i "x86_64\|amd64\|linux" | head -1)

    # If no arch-specific match, try any AppImage
    if [[ -z "$download_url" ]]; then
        download_url=$(echo "$release_json" | grep -o '"browser_download_url"[[:space:]]*:[[:space:]]*"[^"]*\.AppImage"' | cut -d'"' -f4 | head -1)
    fi

    if [[ -z "$download_url" ]]; then
        error "No AppImage found in the latest release"
        echo "Check: https://github.com/${owner}/${repo}/releases/latest"
        exit 1
    fi

    info "Downloading: $(basename "$download_url")"

    # Download to temp
    local tmpfile
    tmpfile=$(mktemp --suffix=.AppImage)
    if ! curl -L --progress-bar -o "$tmpfile" "$download_url"; then
        error "Download failed"
        rm -f "$tmpfile"
        exit 1
    fi

    chmod +x "$tmpfile"
    ok "Downloaded $(du -h "$tmpfile" | cut -f1)"

    # Check if desktop entry has --no-sandbox
    local no_sandbox_flag=""
    local desktop_file="${DESKTOP_DIR}/${app_name}.desktop"
    if [[ -f "$desktop_file" ]] && grep -q "\-\-no-sandbox" "$desktop_file"; then
        no_sandbox_flag="--no-sandbox"
    fi

    # Re-install (do_install handles replacing existing)
    APPIMAGE_PATH="$tmpfile"
    info "Installing update..."

    # Extract
    local tmpdir
    tmpdir=$(mktemp -d)
    (cd "$tmpdir" && "$tmpfile" --appimage-extract > /dev/null 2>&1)

    if [[ ! -d "${tmpdir}/squashfs-root" ]]; then
        error "Extraction failed"
        rm -rf "$tmpdir" "$tmpfile"
        exit 1
    fi

    # Patch AppRun
    local apprun="${tmpdir}/squashfs-root/AppRun"
    if [[ -f "$apprun" ]] && grep -q 'if \[ -z "$APPDIR" \]' "$apprun" 2>/dev/null; then
        sed -i '/if \[ -z "$APPDIR" \]/,/^fi$/c\APPDIR="$(dirname "$(readlink -f "${THIS}")")"' "$apprun"
    fi

    # Replace installation
    rm -rf "$install_path"
    mv "${tmpdir}/squashfs-root" "$install_path"
    rm -rf "$tmpdir" "$tmpfile"

    # Update icon in desktop entry
    local icon_path
    icon_path=$(find_icon "$install_path")
    if [[ -z "$icon_path" ]]; then
        icon_path=$(find "${install_path}" -maxdepth 1 -name "*.png" 2>/dev/null | head -1)
    fi
    if [[ -n "$icon_path" ]]; then
        icon_path=$(readlink -f "$icon_path" 2>/dev/null || echo "$icon_path")
    fi

    # Rebuild desktop entry (preserve settings)
    local display_name wm_class mimetype categories
    local app_desktop
    app_desktop=$(find_desktop_file "$install_path")
    if [[ -n "$app_desktop" ]]; then
        display_name=$(grep -i "^Name=" "$app_desktop" 2>/dev/null | head -1 | cut -d= -f2)
        wm_class=$(grep -i "^StartupWMClass=" "$app_desktop" 2>/dev/null | cut -d= -f2)
        mimetype=$(grep -i "^MimeType=" "$app_desktop" 2>/dev/null | cut -d= -f2)
        categories=$(grep -i "^Categories=" "$app_desktop" 2>/dev/null | cut -d= -f2)
    fi
    display_name="${display_name:-$app_name}"
    categories="${categories:-Development;}"

    local exec_line="env -u APPDIR -u ELECTRON_RUN_AS_NODE -u DESKTOPINTEGRATION ${install_path}/AppRun"
    if [[ -n "$no_sandbox_flag" ]]; then
        exec_line="${exec_line} --no-sandbox"
    fi
    exec_line="${exec_line} %U"

    {
        echo "[Desktop Entry]"
        echo "Name=${display_name}"
        echo "Exec=${exec_line}"
        echo "Terminal=false"
        echo "Type=Application"
        [[ -n "$icon_path" ]] && echo "Icon=${icon_path}"
        [[ -n "$wm_class" ]] && echo "StartupWMClass=${wm_class}"
        [[ -n "$mimetype" ]] && echo "MimeType=${mimetype}"
        echo "Categories=${categories}"
        echo "X-AppImage-Version=${latest_version}"
        echo "X-InstalledBy=appimage-install"
    } > "$desktop_file"

    # Update bin symlink
    ln -sf "${install_path}/AppRun" "${BIN_DIR}/${app_name}"

    update-desktop-database "$DESKTOP_DIR" 2>/dev/null || true

    echo ""
    ok "Updated ${display_name}: ${current_version} → ${latest_version}"
}

do_update_all() {
    info "Checking all installed apps for updates..."
    echo ""

    local found=false
    for desktop_file in "${DESKTOP_DIR}"/*.desktop; do
        [[ -f "$desktop_file" ]] || continue
        if grep -q "X-InstalledBy=appimage-install" "$desktop_file" 2>/dev/null; then
            local app_name
            app_name=$(basename "$desktop_file" .desktop)
            local install_path="${INSTALL_DIR}/${app_name}"

            if get_update_info "$install_path" > /dev/null 2>&1; then
                do_update "$app_name" || warn "Failed to update ${app_name}"
                echo ""
                found=true
            fi
        fi
    done

    # Also check manually extracted apps (t3code, opencode)
    for app_dir in "${INSTALL_DIR}"/*/; do
        [[ -d "$app_dir" ]] || continue
        local app_name
        app_name=$(basename "$app_dir")
        local desktop_file="${DESKTOP_DIR}/${app_name}.desktop"

        # Skip if already processed above
        if [[ -f "$desktop_file" ]] && grep -q "X-InstalledBy=appimage-install" "$desktop_file" 2>/dev/null; then
            continue
        fi

        if get_update_info "$app_dir" > /dev/null 2>&1; then
            info "Found updatable app: ${app_name}"
            do_update "$app_name" || warn "Failed to update ${app_name}"
            echo ""
            found=true
        fi
    done

    if [[ "$found" == false ]]; then
        ok "No updatable apps found"
    fi
}

do_install() {
    local appimage="$1"
    shift

    local custom_name=""
    local no_sandbox=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name)
                custom_name="$2"
                shift 2
                ;;
            --no-sandbox)
                no_sandbox=true
                shift
                ;;
            *)
                error "Unknown option: $1"
                exit 1
                ;;
        esac
    done

    # Resolve to absolute path
    APPIMAGE_PATH="$(realpath "$appimage")"

    if [[ ! -f "$APPIMAGE_PATH" ]]; then
        error "File not found: $appimage"
        exit 1
    fi

    if [[ ! "$APPIMAGE_PATH" == *.AppImage ]] && [[ ! "$APPIMAGE_PATH" == *.appimage ]]; then
        error "Not an AppImage file: $appimage"
        exit 1
    fi

    if [[ ! -x "$APPIMAGE_PATH" ]]; then
        chmod +x "$APPIMAGE_PATH"
    fi

    # Extract
    info "Extracting AppImage..."
    local tmpdir
    tmpdir=$(mktemp -d)
    (cd "$tmpdir" && "$APPIMAGE_PATH" --appimage-extract > /dev/null 2>&1)

    if [[ ! -d "${tmpdir}/squashfs-root" ]]; then
        error "Extraction failed"
        rm -rf "$tmpdir"
        exit 1
    fi

    # Fix AppRun: force APPDIR instead of conditionally setting it
    # Without this, inherited APPDIR from other AppImages breaks launches
    local apprun="${tmpdir}/squashfs-root/AppRun"
    if [[ -f "$apprun" ]] && grep -q 'if \[ -z "$APPDIR" \]' "$apprun" 2>/dev/null; then
        sed -i '/if \[ -z "$APPDIR" \]/,/^fi$/c\APPDIR="$(dirname "$(readlink -f "${THIS}")")"' "$apprun"
        ok "Patched AppRun (fixed APPDIR detection)"
    fi

    # Detect app metadata
    local app_name
    if [[ -n "$custom_name" ]]; then
        app_name="$custom_name"
    else
        app_name=$(detect_name "${tmpdir}/squashfs-root")
    fi

    local display_name
    display_name=$(detect_display_name "${tmpdir}/squashfs-root")
    local categories
    categories=$(detect_categories "${tmpdir}/squashfs-root")
    local wm_class
    wm_class=$(detect_wm_class "${tmpdir}/squashfs-root")
    local mimetype
    mimetype=$(detect_mimetype "${tmpdir}/squashfs-root")
    local icon_path
    icon_path=$(find_icon "${tmpdir}/squashfs-root")

    info "App name:     ${app_name}"
    info "Display name: ${display_name}"

    # Check for existing installation
    local install_path="${INSTALL_DIR}/${app_name}"
    if [[ -d "$install_path" ]]; then
        warn "Existing installation found at ${install_path}"
        warn "Replacing with new version..."
        rm -rf "$install_path"
    fi

    # Move to install directory
    mkdir -p "$INSTALL_DIR"
    mv "${tmpdir}/squashfs-root" "$install_path"
    rm -rf "$tmpdir"
    ok "Extracted to ${install_path}"

    # Resolve icon (now relative to install path)
    if [[ -n "$icon_path" ]]; then
        icon_path="${install_path}/${icon_path#${install_path}/}"
        # If it was a relative path from squashfs-root, fix it
        icon_path=$(echo "$icon_path" | sed "s|.*/squashfs-root/|${install_path}/|")
        # Resolve symlinks to get a real file
        if [[ -L "$icon_path" ]]; then
            local resolved
            resolved=$(readlink -f "$icon_path" 2>/dev/null)
            if [[ -f "$resolved" ]]; then
                icon_path="$resolved"
            fi
        fi
    fi

    # Find the icon again from the installed location
    icon_path=$(find_icon "$install_path")
    if [[ -z "$icon_path" ]]; then
        # check root-level png
        icon_path=$(find "${install_path}" -maxdepth 1 -name "*.png" 2>/dev/null | head -1)
    fi

    if [[ -n "$icon_path" ]]; then
        # Resolve symlinks
        icon_path=$(readlink -f "$icon_path" 2>/dev/null || echo "$icon_path")
        ok "Icon: ${icon_path}"
    else
        warn "No icon found"
    fi

    # Build Exec line — env -u clears stale vars from other AppImages
    local exec_line="env -u APPDIR -u ELECTRON_RUN_AS_NODE -u DESKTOPINTEGRATION ${install_path}/AppRun"
    if [[ "$no_sandbox" == true ]]; then
        exec_line="${exec_line} --no-sandbox"
    fi
    exec_line="${exec_line} %U"

    # Get version for tracking
    local version=""
    local app_desktop
    app_desktop=$(find_desktop_file "$install_path")
    if [[ -n "$app_desktop" ]]; then
        version=$(grep "^X-AppImage-Version=" "$app_desktop" 2>/dev/null | cut -d= -f2)
    fi
    if [[ -z "$version" ]]; then
        version=$(get_current_version "$install_path")
    fi

    # Create desktop entry
    mkdir -p "$DESKTOP_DIR"
    local desktop_file="${DESKTOP_DIR}/${app_name}.desktop"

    {
        echo "[Desktop Entry]"
        echo "Name=${display_name}"
        echo "Exec=${exec_line}"
        echo "Terminal=false"
        echo "Type=Application"
        [[ -n "$icon_path" ]] && echo "Icon=${icon_path}"
        [[ -n "$wm_class" ]] && echo "StartupWMClass=${wm_class}"
        [[ -n "$mimetype" ]] && echo "MimeType=${mimetype}"
        echo "Categories=${categories}"
        [[ -n "$version" && "$version" != "unknown" ]] && echo "X-AppImage-Version=${version}"
        echo "X-InstalledBy=appimage-install"
    } > "$desktop_file"

    ok "Desktop entry: ${desktop_file}"

    # Create bin symlink
    mkdir -p "$BIN_DIR"
    ln -sf "${install_path}/AppRun" "${BIN_DIR}/${app_name}"
    ok "Command: ${app_name} (in ~/.local/bin/)"

    # Update desktop database
    update-desktop-database "$DESKTOP_DIR" 2>/dev/null || true

    # Remove original AppImage
    info "Removing original AppImage..."
    rm -f "$APPIMAGE_PATH"
    ok "Removed ${APPIMAGE_PATH}"

    echo ""
    ok "Installed ${display_name} successfully!"
    echo ""
    echo "  Launch from menu or run: ${app_name}"
    echo "  Install dir: ${install_path}"
    echo "  Update with: appimage-install --update ${app_name}"
    echo "  Remove with: appimage-install --remove ${app_name}"
}

do_list() {
    info "Installed AppImages:"
    echo ""

    local found=false

    for app_dir in "${INSTALL_DIR}"/*/; do
        [[ -d "$app_dir" ]] || continue
        local app_name
        app_name=$(basename "$app_dir")
        local desktop_file="${DESKTOP_DIR}/${app_name}.desktop"
        local size
        size=$(du -sh "$app_dir" 2>/dev/null | cut -f1 || echo "?")

        local display_name="$app_name"
        local version=""
        local updatable=""

        if [[ -f "$desktop_file" ]]; then
            display_name=$(grep "^Name=" "$desktop_file" 2>/dev/null | cut -d= -f2 || true)
            display_name="${display_name:-$app_name}"
            version=$(grep "^X-AppImage-Version=" "$desktop_file" 2>/dev/null | cut -d= -f2 || true)
        fi

        if [[ -z "$version" ]]; then
            version=$(get_current_version "$app_dir")
        fi

        if get_update_info "$app_dir" > /dev/null 2>&1; then
            updatable=" [updatable]"
        fi

        echo -e "  ${GREEN}${app_name}${NC}  ${display_name}  v${version}  (${size})${updatable}"
        found=true
    done

    if [[ "$found" == false ]]; then
        echo "  No apps installed yet."
    fi
}

do_remove() {
    local app_name="$1"

    if [[ -z "$app_name" ]]; then
        error "Usage: appimage-install --remove <name>"
        exit 1
    fi

    local install_path="${INSTALL_DIR}/${app_name}"
    local desktop_file="${DESKTOP_DIR}/${app_name}.desktop"
    local bin_link="${BIN_DIR}/${app_name}"

    if [[ ! -d "$install_path" ]] && [[ ! -f "$desktop_file" ]]; then
        error "App '${app_name}' not found"
        echo "Run 'appimage-install --list' to see installed apps"
        exit 1
    fi

    info "Removing ${app_name}..."

    [[ -d "$install_path" ]] && rm -rf "$install_path" && ok "Removed ${install_path}"
    [[ -f "$desktop_file" ]] && rm -f "$desktop_file" && ok "Removed ${desktop_file}"
    [[ -L "$bin_link" ]] && rm -f "$bin_link" && ok "Removed ${bin_link}"

    update-desktop-database "$DESKTOP_DIR" 2>/dev/null || true

    ok "Uninstalled ${app_name}"
}

do_check_updates() {
    local updates_available=""
    local count=0

    for app_dir in "${INSTALL_DIR}"/*/; do
        [[ -d "$app_dir" ]] || continue
        local app_name
        app_name=$(basename "$app_dir")

        local yml
        yml=$(get_update_info "$app_dir") || continue

        local owner repo
        owner=$(grep "^owner:" "$yml" | awk '{print $2}' | tr -d '[:space:]')
        repo=$(grep "^repo:" "$yml" | awk '{print $2}' | tr -d '[:space:]')
        local provider
        provider=$(grep "^provider:" "$yml" | awk '{print $2}' | tr -d '[:space:]')

        [[ "$provider" != "github" ]] && continue
        [[ -z "$owner" || -z "$repo" ]] && continue

        local current_version
        current_version=$(get_current_version "$app_dir")

        local release_json latest_version
        release_json=$(curl -sL "https://api.github.com/repos/${owner}/${repo}/releases/latest" 2>/dev/null)
        latest_version=$(echo "$release_json" | grep -o '"tag_name"[[:space:]]*:[[:space:]]*"[^"]*"' | cut -d'"' -f4 | sed 's/^v//')

        [[ -z "$latest_version" ]] && continue

        if [[ "$current_version" != "$latest_version" ]]; then
            local display_name="$app_name"
            local desktop_file="${DESKTOP_DIR}/${app_name}.desktop"
            if [[ -f "$desktop_file" ]]; then
                display_name=$(grep "^Name=" "$desktop_file" 2>/dev/null | cut -d= -f2 || true)
                display_name="${display_name:-$app_name}"
            fi
            updates_available="${updates_available}${display_name}: ${current_version} → ${latest_version}\n"
            ((count++)) || true
        fi
    done

    if [[ $count -gt 0 ]]; then
        local summary="${count} AppImage update(s) available"
        local body
        body=$(echo -e "$updates_available" | head -5)

        # Send desktop notification
        notify-send -a "AppImage Installer" -i system-software-update \
            "$summary" "$body\n\nRun: appimage-install --update-all" 2>/dev/null || true

        # Also print to stdout (for systemd journal)
        echo "$summary"
        echo -e "$updates_available"
    fi
}

# Main
case "${1:-}" in
    --help|-h|"")
        usage
        ;;
    --list|-l)
        do_list
        ;;
    --remove|-r)
        do_remove "${2:-}"
        ;;
    --update|-u)
        do_update "${2:-}"
        ;;
    --update-all|-U)
        do_update_all
        ;;
    --check-updates|-c)
        do_check_updates
        ;;
    *)
        do_install "$@"
        ;;
esac
